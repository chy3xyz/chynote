if [ -z "$NODE_PATH" ]; then
  export NODE_PATH="/Users/n0x/w4_proj/zigmodu_ws/chynote/tolaria-zn/frontend/node_modules/.pnpm/katex@0.16.46/node_modules/katex/node_modules:/Users/n0x/w4_proj/zigmodu_ws/chynote/tolaria-zn/frontend/node_modules/.pnpm/katex@0.16.46/node_modules:/Users/n0x/w4_proj/zigmodu_ws/chynote/tolaria-zn/frontend/node_modules/.pnpm/node_modules"
else
